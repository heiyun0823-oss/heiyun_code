{
  "name": "heiyun-code",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/ai",
    "packages/tools",
    "packages/agent-core",
    "packages/cli"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "clean": "rm -rf packages/*/dist",
    "publish": "npm run build && npm publish -w packages/cli",
    "publish:dry": "npm run build && npm publish -w packages/cli --dry-run"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "20.19.41",
    "tsup": "8.5.1",
    "tsx": "4.22.4",
    "typescript": "5.9.3"
  }
}
